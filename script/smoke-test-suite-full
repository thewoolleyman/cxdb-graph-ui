#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

failed=0

run_step() {
  local label="$1"
  shift
  echo "==> ${label}"
  if "$@"; then
    echo "    ✓ passed"
  else
    echo "    ✗ FAILED"
    failed=1
  fi
  echo
}

# Rust fmt/clippy/build/test — only run if server/Cargo.toml exists (created by the Kilroy implement node)
if [ -f "${REPO_ROOT}/server/Cargo.toml" ]; then
  run_step "cargo fmt --check" bash -c "cd '${REPO_ROOT}/server' && cargo fmt --check"
  run_step "cargo clippy" bash -c "cd '${REPO_ROOT}/server' && cargo clippy -- -D warnings -D clippy::unwrap_used -D clippy::expect_used -D clippy::panic -D clippy::unwrap_in_result"
  run_step "cargo build" bash -c "cd '${REPO_ROOT}/server' && cargo build"
  run_step "cargo test" bash -c "cd '${REPO_ROOT}/server' && cargo test"
else
  echo "==> cargo fmt/clippy/build/test"
  echo "    (skipped: server/Cargo.toml not yet created)"
  echo
fi

# Skill tests: kilroy-generate-pipeline (Ruby/Minitest)
run_step "kilroy-generate-pipeline tests" bash "${REPO_ROOT}/.claude/skills/kilroy-generate-pipeline/tests/run_tests.sh"

# Skill tests: spec-critique-revise-loop (bash unit tests)
run_step "spec-critique-revise-loop tests" bash "${REPO_ROOT}/.claude/skills/spec-critique-revise-loop/tests/run_tests.sh"

if [ "$failed" -ne 0 ]; then
  echo "Some steps failed."
  exit 1
fi

echo "All checks passed."
