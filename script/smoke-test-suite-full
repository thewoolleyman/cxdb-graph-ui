#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

failed=0

run_step() {
  local label="$1"
  shift
  echo "==> ${label}"
  if "$@"; then
    echo "    ✓ passed"
  else
    echo "    ✗ FAILED"
    failed=1
  fi
  echo
}

# Go vet/test — only run if ui/ exists (created by the Kilroy implement node)
if [ -d "${REPO_ROOT}/ui" ]; then
  run_step "go vet" bash -c "cd '${REPO_ROOT}/ui' && go vet ./..."
  run_step "go test" bash -c "cd '${REPO_ROOT}/ui' && go test ./..."
else
  echo "==> go vet/test"
  echo "    (skipped: ui/ not yet created)"
  echo
fi

# Skill tests: kilroy-generate-pipeline (Ruby/Minitest)
run_step "kilroy-generate-pipeline tests" bash "${REPO_ROOT}/.claude/skills/kilroy-generate-pipeline/tests/run_tests.sh"

# Skill tests: spec-critique-revise-loop (bash unit tests)
run_step "spec-critique-revise-loop tests" bash "${REPO_ROOT}/.claude/skills/spec-critique-revise-loop/tests/run_tests.sh"

if [ "$failed" -ne 0 ]; then
  echo "Some steps failed."
  exit 1
fi

echo "All checks passed."
