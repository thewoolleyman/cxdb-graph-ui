{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "gitlab/duo-chat-haiku-4-5",
  "share": "disabled",
  "mcp": {
    "knowledge-graph": {
      "type": "remote",
      "url": "http://localhost:27495/mcp/sse"
    }
  },
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "echo*": "allow",
      "git add*": "allow",
      "git blame*": "allow",
      "git branch*": "allow",
      "git diff*": "allow",
      "git --no-pager diff*": "allow",
      "git grep*": "allow",
      "git log*": "allow",
      "git ls-files*": "allow",
      "git rev-parse*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "cargo build*": "allow",
      "cargo test*": "allow",
      "cargo clippy*": "allow",
      "cargo fmt*": "allow",
      "cargo check*": "allow",
      "cargo run*": "allow",
      "make *": "allow",
      "grep*": "allow",
      "head*": "allow",
      "ls*": "allow",
      "pre-commit *": "allow",
      "sleep *": "allow",
      "tail*": "allow",
      "wc *": "allow",
      "which*": "allow"
    },
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "todowrite": "allow"
  }
}
